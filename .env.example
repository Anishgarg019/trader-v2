# Copy to `.env` and fill in. NEVER commit `.env`.

# --- Mode (must always be 'paper'; the safety guard refuses anything else) ---
MODE=paper

# --- Zerodha Kite Connect (READ-ONLY data use only) ---
# From https://developers.kite.trade/ → your app
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
# Daily access token — minted by the login helpers (expires ~6 AM IST).
# Leave blank; the login helper writes it (and/or .kite_token.json).
KITE_ACCESS_TOKEN=

# --- UNATTENDED daily login (scripts/auto_login.py) — fills KITE_ACCESS_TOKEN automatically ---
# Set these three to mint the daily token headlessly (TOTP 2FA) so you NEVER have to log in by
# hand. Used only to obtain the READ-ONLY data token — never to place orders. Leave blank to
# keep doing the manual `python scripts/kite_login.py` instead.
#   KITE_USER_ID      your Zerodha client id (e.g. VVX933)
#   KITE_PASSWORD     your Zerodha login password
#   KITE_TOTP_SECRET  the base32 SEED behind your 2FA TOTP (the "enter this key manually"
#                     string shown when setting up the authenticator app) — NOT a 6-digit code.
KITE_USER_ID=
KITE_PASSWORD=
KITE_TOTP_SECRET=

# --- Obsidian vault (where the agent writes notes) ---
# Mac dev default below; on the Windows box set this to your real Obsidian vault path,
# e.g. C:\Users\you\Documents\TradingVault
VAULT_PATH=./vault-dev

# --- Daily-login reminder via ntfy (optional) ---
# Pick a hard-to-guess topic, subscribe to it in the ntfy app (ntfy.sh) on your phone,
# and schedule scripts/notify_login.py at 07:30 IST to get a daily push.
NTFY_TOPIC=
NTFY_SERVER=https://ntfy.sh

# --- Cloud dashboard (optional) ---
# Postgres/Supabase connection string the agent PUSHES performance data to. Leave blank to
# disable publishing. This is PERFORMANCE DATA ONLY — never Kite keys. The Streamlit app
# uses the same URL (set as a Streamlit Cloud secret) plus DASHBOARD_PASSWORD.
DASHBOARD_DB_URL=
